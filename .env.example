# Copy this file to .env and fill in your values:
#   copy .env.example .env

# OpenRouter — used for the main LLM agent
OPENROUTER_API_KEY=your_openrouter_api_key_here
MODEL_NAME=openrouter/owl-alpha

# Wake word phrase (optional, defaults to "zara")
WAKE_WORD=zara

# Google Gemini — used for intent classification
GEMINI_API_KEY=your_gemini_api_key_here

# Optional overrides:
# INTENT_MODEL=gemini-2.0-flash
# INTENT_CONFIDENCE_THRESHOLD=0.7

# Voice / VAD (no fixed recording timer):
# VOICE_SILENCE_TIMEOUT=2.0
# WAKE_TIMEOUT=25
# MINIMUM_SPEECH_DURATION=0.3
# CONTINUOUS_CONVERSATION=true   # default: stay listening after each reply
# CONTINUOUS_CONVERSATION=false  # one command per wake word (old behaviour)
